PRIVATE_KEY=61be2aa391837c9e26e5ba512b15b180384547959a412c5556aefa631ef18b98

# ========================================
# TRADING CONFIGURATION
# ========================================
# Minimum profit in USD to execute trade
MIN_PROFIT_THRESHOLD=1

# Gas fee safety multiplier (1.2 = 20% buffer)
GAS_MULTIPLIER=1.2

# Maximum allowed slippage percentage (0.5%)
MAX_SLIPPAGE=0.5

# Number of price quotes to buffer before checking
BUFFER_SIZE=10

# ========================================
# NETWORK CONFIGURATION
# ========================================
# Which network to trade on: ethereum, polygon, arbitrum, bsc, sepolia
TRADING_NETWORK=sepolia

# Override RPC endpoints (leave empty to use defaults from config.json)
ETHEREUM_RPC=
POLYGON_RPC=
ARBITRUM_RPC=
BSC_RPC=
SEPOLIA_RPC=https://rpc.sepolia.org

# ========================================
# TOKEN CONFIGURATION
# ========================================
# Target token address (example: WBTC on Ethereum)
TOKEN_ADDRESS=0x2260fac5e5542a773aa44fbcfedf7c193bc2c599

# Base currency for trading (usdt, usdc, or dai)
BASE_CURRENCY=usdt

# ========================================
# SWAP EXECUTION SETTINGS
# ========================================
# Amount of tokens to swap per trade (in decimal format)
SWAP_AMOUNT=1

# Uniswap V3 fee tier (3000 = 0.3%, 500 = 0.05%, 10000 = 1%)
FEE_TIER=3000

# Deadline for swap execution (in minutes)
SWAP_DEADLINE_MINUTES=20

# Gas limit for swap transaction
GAS_LIMIT=500000

# ========================================
# MONITORING SETTINGS
# ========================================
# How long WebSocket stays connected (seconds)
CONNECTION_TIMEOUT_SECONDS=300

# Log keep-alive messages (true/false)
LOG_KEEP_ALIVE=false

# Enable detailed logging
DEBUG_MODE=false
